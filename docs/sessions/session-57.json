{
  "session_id": "session-57",
  "phase_id": "phase13",
  "title": "live api end-to-end validation with test-only scope",
  "goal": "OpenAI API と Claude API を使った run_session.py の本番1本通しを、安全な test-only 範囲で完走検証する",
  "execution_method": "orchestrator_live_run",

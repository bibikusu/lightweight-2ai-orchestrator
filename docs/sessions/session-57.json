      "description": "mock や dry-run ではなく実 API 接続で検証する"
    },
    {
      "name": "execution_method",
      "type": "enum[orchestrator_live_run]",
      "description": "Cursor 実装セッションではなく run_session.py 自身が実行主体"
    },
    {
      "name": "allowed_test_file",
      "type": "str",
      "description": "backend/tests/test_live_api_validation.py"
    },
    {
      "name": "forbidden_runtime_file",
      "type": "str",
      "description": "orchestration/run_session.py"
    },
    {
      "name": "sandbox_branch",
      "type": "str",
      "description": "sandbox/session-57"
    }
  ],
  "outputs": [
    {
      "name": "new_test_file",
      "type": "str",
      "description": "backend/tests/test_live_api_validation.py"
    },
    {

    {
      "id": "AC-46-05",
      "description": "session-46.yaml の acceptance が正常系、異常系、既存成果物非破壊、副作用なしを含み、各項目が test_name と 1対1対応する",
      "test_name": "test_acceptance_46_has_complete_one_to_one_mapping",
      "test_action": "create"
    },
    {
      "id": "AC-46-06",
      "description": "allowed_changes が docs/sessions/session-46.json と docs/acceptance/session-46.yaml の2ファイルのみに限定されている",
      "test_name": "test_session_46_allowed_changes_are_limited",
      "test_action": "create"
    }

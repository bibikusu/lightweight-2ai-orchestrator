          "function": "load_session_context",
          "usage": "safe_load した acceptance YAML を parsed として保持"
        },
        {
          "function": "build_session_report_record",
          "usage": "acceptance[].test_name を test_function_results と照合して result を算出"
        },
        {
          "function": "build_acceptance_results_for_report_json",
          "usage": "report.json 用 acceptance_results を生成"
        }
      ],

  "runtime_flow_contract": {
    "type": "list[object]",
    "value": [
      {
        "order": 1,
        "stage": "loading",
        "functions": [
          "load_session_context"
        ],
        "input": [
          "docs/sessions/<session_id>.json",
          "docs/acceptance/<acceptance_ref>.yaml",
          "docs/master_instruction.md",
          "docs/global_rules.md",
          "docs/roadmap.yaml",
          "orchestration/config.yaml"
        ],
        "output": [
          "SessionContext"
        ]
      },
      {
        "order": 2,
        "stage": "validating",
        "functions": [
          "validate_session_context"
        ],
        "input": [
          "SessionContext.session_data"
        ],
        "output": [
          "validated SessionContext"
        ]
      },
      {
        "order": 3,
        "stage": "prepared_spec",
        "functions": [
          "build_prepared_spec_prompts",
          "call_chatgpt_for_prepared_spec"
        ],
        "input": [
          "SessionContext.master_instruction",
          "SessionContext.global_rules",
          "SessionContext.roadmap_text",
          "SessionContext.session_data",
          "SessionContext.acceptance_data.raw_yaml"
        ],
        "output": [
          "prepared_spec.json"
        ]
      },
      {
        "order": 4,
        "stage": "implementation",
        "functions": [
          "build_implementation_prompts",
          "call_claude_for_implementation"
        ],
        "input": [
          "prepared_spec",
          "SessionContext.session_data",
          "retry_instruction（任意）"
        ],
        "output": [
          "implementation_result.json"
        ]
      },
      {
        "order": 5,
        "stage": "patch_validation",
        "functions": [
          "validate_changed_files_before_patch"
        ],
        "input": [
          "implementation_result.changed_files",
          "prepared_spec.allowed_changes",
          "prepared_spec.forbidden_changes",
          "SessionContext.session_data.out_of_scope"
        ],
        "output": [
          "validation pass/fail"
        ]
      },
      {
        "order": 6,
        "stage": "checks",
        "functions": [
          "run_local_checks"
        ],
        "input": [
          "runtime_config.commands"
        ],
        "output": [
          "checks.json"
        ]
      },
      {
        "order": 7,
        "stage": "retry_decision",
        "functions": [
          "classify_failure",
          "resolve_canonical_failure_type",
          "retry_loop",
          "build_retry_prompts",
          "call_chatgpt_for_retry_instruction"
        ],
        "input": [
          "checks",
          "prepared_spec",
          "implementation_result",
          "retry_history",
          "retry_count"
        ],
        "output": [
          "retry_instruction.json",
          "updated retry_count"
        ]
      },
      {
        "order": 8,
        "stage": "report",
        "functions": [
          "generate_report",
          "build_session_report_record",
          "build_acceptance_results_for_report_json",
          "persist_session_reports"
        ],
        "input": [
          "SessionContext",
          "prepared_spec",
          "implementation_result",
          "checks",
          "retry_instruction（任意）"
        ],
        "output": [
          "reports/session_report.md",
          "reports/session_report.json",
          "report.json"
        ]
      }
    ]
  },
  "failure_retry_contract": {
    "type": "object",
    "schema": {
      "failure_type_source": "list[object]",
      "retry_trigger_point": "list[object]",
      "retry_stop_conditions": "list[object]",
      "report_reflection": "list[object]"
    },
    "value": {
      "failure_type_source": [
        {
          "function": "classify_failure",
          "usage": "retry_loop 用の failure_type と cause_summary の生成"
        },
        {
          "function": "resolve_canonical_failure_type",
          "usage": "report.json / retry_instruction 正規化用の canonical failure_type 決定"
        }
      ],
      "retry_trigger_point": [
        {
          "location": "main while not check_results.success",
          "condition": "checks.success == false",
          "effect": "retry_instruction を生成し Claude を再呼び出しする"
        }
      ],
      "retry_stop_conditions": [
        {
          "condition": "same_failure_and_cause",
          "source": "retry_loop / cause fingerprint comparison"
        },
        {
          "condition": "max_retries_reached",
          "source": "retry_loop / max_retries_effective"
        },
        {
          "condition": "failure_type_repeated",
          "source": "retry_loop / previous failure_type comparison"
        }
      ],
      "report_reflection": [
        {
          "function": "persist_session_reports",
          "usage": "failure_type, retry_count, retry_stopped_same_cause, retry_stopped_max_retries を report.json に反映"
        }
      ]
    }
  },
